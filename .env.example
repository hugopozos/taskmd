# TaskMD environment variables
# Copy this file to .env and edit values as needed.

# User/group ID for the Docker container.
# Should match the host user that owns todo.md and archive/.
# UID=1000
# GID=1000

# Server bind address (only used for Docker).
# Default is 127.0.0.1 (localhost-only, safe for public repos).
# Set to 0.0.0.0 to expose on all interfaces (e.g. Tailscale LAN access).
# Do not commit 0.0.0.0 to a public repository without understanding the risks.
# TASKMD_BIND=127.0.0.1

# Optional: commit author used by the backend git auto-commit.
# If unset, the container uses the host's git config.
# GIT_AUTHOR_NAME=TaskMD
# GIT_AUTHOR_EMAIL=taskmd@example.com
